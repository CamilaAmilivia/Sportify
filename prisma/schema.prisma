generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Rol {
  CLIENTE
  PROFESOR
  ADMIN
}

enum EstadoClase {
  ACTIVA
  CANCELADA
  FINALIZADA
}

enum EstadoInscripcion {
  ACTIVA
  CANCELADA
}

enum EstadoPago {
  PENDIENTE
  APROBADO
  RECHAZADO
  CANCELADO
}

enum TipoPago {
  MENSUALIDAD
  CLASE_INDIVIDUAL
}

enum TipoListaEspera {
  ABONADO
  CLASE_INDIVIDUAL
}

enum TipoPenalizacion {
  AVISO_CANCELACION_TARDIA_ABONO
  RECARGO_CLASE_INDIVIDUAL
  RECARGO_ABONO
}

model Usuario {
  id         Int       @id @default(autoincrement())
  dni        Int       @unique
  nombre     String
  apellido   String
  email      String    @unique
  password   String
  fechaNac   DateTime?
  aptoFisico String?
  rol        Rol
  activo     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  clasesProfesor Clase[]       @relation("ProfesorClase")
  inscripciones  Inscripcion[]
  listaEspera    ListaEspera[]
  asistencias    Asistencia[]
  pagos          Pago[]
  penalizaciones Penalizacion[]
  creditosClase  CreditoClase[]
  passwordResetTokens PasswordResetToken[]
}

model Disciplina {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now())

  clases Clase[]
}

model Clase {
  id          Int         @id @default(autoincrement())
  titulo      String
  descripcion String?
  fechaHora   DateTime
  duracionMin Int
  cupoMaximo  Int        @default(1)
  precio      Float      @default(0)
  estado      EstadoClase @default(ACTIVA)
  qrActivo    Boolean    @default(false)
  serieId     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  disciplinaId Int
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id])

  profesorId Int
  profesor   Usuario @relation("ProfesorClase", fields: [profesorId], references: [id])

  inscripciones Inscripcion[]
  listaEspera   ListaEspera[]
  asistencias   Asistencia[]
  pagos         Pago[]
  penalizaciones Penalizacion[]
  creditosOrigen CreditoClase[] @relation("CreditoOrigen")
  creditosUsados CreditoClase[] @relation("CreditoUsado")
}

model Inscripcion {
  id        Int               @id @default(autoincrement())
  estado    EstadoInscripcion @default(ACTIVA)
  createdAt DateTime          @default(now())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  claseId Int
  clase   Clase @relation(fields: [claseId], references: [id])

  pagoId Int?
  pago   Pago? @relation(fields: [pagoId], references: [id])

  @@unique([usuarioId, claseId])
}

model ListaEspera {
  id           Int      @id @default(autoincrement())
  posicion     Int
  tipo         TipoListaEspera @default(CLASE_INDIVIDUAL)
  prioridad    Int      @default(0)
  createdAt    DateTime @default(now())
  notificadoEn DateTime?

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  claseId Int
  clase   Clase @relation(fields: [claseId], references: [id])

  pagoId Int?
  pago   Pago? @relation(fields: [pagoId], references: [id])

  @@unique([usuarioId, claseId])
  @@index([claseId])
  @@index([tipo])
  @@index([prioridad])
}

model Asistencia {
  id        Int      @id @default(autoincrement())
  presente  Boolean  @default(true)
  createdAt DateTime @default(now())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  claseId Int
  clase   Clase @relation(fields: [claseId], references: [id])

  @@unique([usuarioId, claseId])
}

model Pago {
  id        Int        @id @default(autoincrement())
  monto     Float
  estado    EstadoPago @default(PENDIENTE)
  tipo      TipoPago
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  externalReference        String? @unique
  mercadoPagoPreferenceId  String? @unique
  mercadoPagoPaymentId     String? @unique
  initPoint                String?
  reservaHasta             DateTime?

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  claseId Int?
  clase   Clase? @relation(fields: [claseId], references: [id])

  penalizacionId Int?
  penalizacion   Penalizacion? @relation(fields: [penalizacionId], references: [id])

  inscripciones Inscripcion[]
  listaEspera   ListaEspera[]

  @@index([usuarioId])
  @@index([claseId])
  @@index([estado])
}

model CreditoClase {
  id        Int       @id @default(autoincrement())
  motivo    String
  usado     Boolean   @default(false)
  createdAt DateTime  @default(now())
  usadoEn   DateTime?

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  claseOrigenId Int?
  claseOrigen   Clase? @relation("CreditoOrigen", fields: [claseOrigenId], references: [id])

  claseUsadaId Int?
  claseUsada   Clase? @relation("CreditoUsado", fields: [claseUsadaId], references: [id])

  @@index([usuarioId])
  @@index([usado])
}

model Penalizacion {
  id          Int              @id @default(autoincrement())
  tipo        TipoPenalizacion
  porcentaje  Float            @default(0)
  motivo      String
  aplicada    Boolean          @default(false)
  createdAt   DateTime         @default(now())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  claseId Int?
  clase   Clase? @relation(fields: [claseId], references: [id])

  pagos Pago[]

  @@index([usuarioId])
  @@index([tipo])
  @@index([aplicada])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  @@index([token])
  @@index([usuarioId])
}
