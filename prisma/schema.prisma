generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Rol {
  CLIENTE
  PROFESOR
  ADMIN
}

enum EstadoClase {
  ACTIVA
  CANCELADA
  FINALIZADA
}

enum EstadoInscripcion {
  ACTIVA
  CANCELADA
}

enum EstadoPago {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum TipoPago {
  MENSUALIDAD
  CLASE_INDIVIDUAL
}

model Usuario {
  id         Int       @id @default(autoincrement())
  dni        Int       @unique
  nombre     String
  apellido   String
  email      String    @unique
  password   String
  fechaNac   DateTime?
  aptoFisico String?
  rol        Rol
  activo     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  clasesProfesor Clase[]       @relation("ProfesorClase")
  inscripciones  Inscripcion[]
  listaEspera    ListaEspera[]
  asistencias    Asistencia[]
  pagos          Pago[]
}

model Disciplina {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now())

  clases Clase[]
}

model Clase {
  id          Int         @id @default(autoincrement())
  titulo      String
  descripcion String?
  fechaHora   DateTime
  duracionMin Int
  cupoMaximo  Int
  estado      EstadoClase @default(ACTIVA)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  disciplinaId Int
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id])

  profesorId Int
  profesor   Usuario @relation("ProfesorClase", fields: [profesorId], references: [id])

  inscripciones Inscripcion[]
  listaEspera   ListaEspera[]
  asistencias   Asistencia[]
}

model Inscripcion {
  id        Int               @id @default(autoincrement())
  estado    EstadoInscripcion @default(ACTIVA)
  createdAt DateTime          @default(now())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  claseId Int
  clase   Clase @relation(fields: [claseId], references: [id])

  pagoId Int?
  pago   Pago? @relation(fields: [pagoId], references: [id])

  @@unique([usuarioId, claseId])
}

model ListaEspera {
  id        Int      @id @default(autoincrement())
  posicion  Int
  createdAt DateTime @default(now())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  claseId Int
  clase   Clase @relation(fields: [claseId], references: [id])

  @@unique([usuarioId, claseId])
}

model Asistencia {
  id        Int      @id @default(autoincrement())
  presente  Boolean  @default(true)
  createdAt DateTime @default(now())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  claseId Int
  clase   Clase @relation(fields: [claseId], references: [id])

  @@unique([usuarioId, claseId])
}

model Pago {
  id        Int        @id @default(autoincrement())
  monto     Float
  estado    EstadoPago @default(PENDIENTE)
  tipo      TipoPago
  createdAt DateTime   @default(now())

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  inscripciones Inscripcion[]
}
